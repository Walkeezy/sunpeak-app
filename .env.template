# Google service account used to read the webcam Google Sheet.
# Create a service account in the Google Cloud Console with access to the
# Sheets API, share the spreadsheet with its email, and use its credentials here.
# Note: keep the literal \n escapes in the private key; they are unescaped at runtime.
GOOGLE_SHEETS_PRIVATE_KEY=key
GOOGLE_SHEETS_CLIENT_EMAIL=email

# ID of the Google Sheet containing the webcam data
# (the part between /d/ and /edit in the spreadsheet URL).
SPREADSHEET_ID=id

# Mapbox map style and credentials for the map tiles, see https://account.mapbox.com/.
MAPBOX_STYLE_ID=styleid
MAPBOX_USER_ID=user
MAPBOX_ACCESS_TOKEN=token
