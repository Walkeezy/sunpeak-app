{
  "name": "sunpeak-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check:unused": "knip",
    "type-check": "tsc --noEmit",
    "lint": "next typegen && eslint src --ext .ts,.tsx && npm run type-check && npm run check:unused",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "dependencies": {
    "@vercel/analytics": "^1.1.1",
    "leaflet": "^1.9.4",
    "next": "^16.1.1",
    "postcss": "^8.5.3",
    "proj4": "^2.9.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@smartive/eslint-config": "7.0.1",
    "@smartive/prettier-config": "3.1.2",
    "@tailwindcss/postcss": "4.1.18",
    "@types/leaflet": "1.9.21",
    "@types/node": "22.19.11",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "^9.19.0",
    "eslint-config-next": "^16.1.1",
    "googleapis": "171.4.0",
    "jsdom": "26.1.0",
    "knip": "5.83.1",
    "prettier": "^3.0.3",
    "prettier-plugin-tailwindcss": "0.6.14",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
