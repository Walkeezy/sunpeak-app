{
  "name": "sunpeak-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check:unused": "knip",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "lint": "next typegen && eslint src --ext .ts,.tsx && npm run type-check && npm run check:unused",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.0",
    "googleapis": "173.0.0",
    "leaflet": "^1.9.4",
    "next": "^16.1.1",
    "proj4": "^2.9.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@smartive/eslint-config": "7.0.1",
    "@smartive/prettier-config": "3.1.2",
    "@tailwindcss/postcss": "4.3.3",
    "@types/leaflet": "1.9.21",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "postcss": "8.5.21",
    "knip": "6.27.0",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.1",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
